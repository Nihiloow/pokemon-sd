<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sdlikeinterfacetest.ViewController.StartController">
    <children>
        <ImageView fitHeight="600.0" fitWidth="900.0" pickOnBounds="true">
            <image>
                <Image url="@background.jpg" />
            </image>
        </ImageView>

        <Button mnemonicParsing="false" onAction="#onStartClicked" prefHeight="150.0" prefWidth="400.0"
                style="-fx-background-color: #D8B4FE; -fx-background-radius: 50; -fx-border-color: black; -fx-border-radius: 50; -fx-border-width: 3;"
                text="START">
            <font>
                <Font name="System Bold" size="64.0" />
            </font>
        </Button>
    </children>
</StackPane>